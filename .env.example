NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=
MAIL_FROM=Nomadabe Travel <hello@your-domain.com>
N8N_CHAT_WEBHOOK_URL=https://n8n.srv1143150.hstgr.cloud/webhook/nomadabe-ai-chat
N8N_CHAT_WEBHOOK_SECRET=
N8N_CHAT_MODEL=deepseek-v4-flash
# AI chatbot widget is hidden unless this is exactly "1".
# Set to 1 once the n8n AI gateway is back online.
NEXT_PUBLIC_CHATBOT_ENABLED=0
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=
LIBRETRANSLATE_SOURCE_LANG=mn
ADMIN_EMAILS=admin@nomadabe.mn
# Required in production — sign admin sessions. Use a long random value.
ADMIN_SESSION_SECRET=change-this-long-random-secret
# Optional: distributed rate limiting across serverless instances.
# Leave blank to use the per-instance in-memory limiter.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NOMADABE_ALLOW_FILE_STORAGE=0
NOMADABE_ALLOW_FILE_AUTH=0
 
